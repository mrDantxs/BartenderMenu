<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 🔙 TOPO -->
    <include
        android:id="@+id/includeTopBack"
        layout="@layout/include_top_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🧩 PAINEL ESQUERDO -->
    <LinearLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#000000"
        app:layout_constraintWidth_percent="0.35"
        app:layout_constraintTop_toBottomOf="@id/includeTopBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRATANTE(S)"
            android:textColor="#8b949e"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editTextContractorNames"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ex: Ana e João"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@drawable/button_border"
            android:inputType="textCapWords"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSaveContractor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SALVAR CONTRATANTE(S)"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#F28C28"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnReorderTasting"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ORDENAR DEGUSTAÇÃO"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#F28C28"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnOpenMenus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CARDÁPIOS"
            android:textStyle="bold"


            android:textColor="#FFFFFF"
            app:backgroundTint="#F28C28"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAddNewDrink"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ADICIONAR DRINK"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#16C60C"/>

    </LinearLayout>

    <!-- 📋 LISTA DIREITA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewDrinks"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/includeTopBack"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>