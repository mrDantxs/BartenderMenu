<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageButton
        android:id="@+id/btnAdmin"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_settings"
        android:background="@android:color/transparent"
        android:tint="#F28C28"
        android:contentDescription="Admin" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

    <ImageView
        android:id="@+id/imageCocktail"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_cocktail"
        android:scaleType="fitCenter"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/imageTitle"
        android:layout_width="260dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_perform"
        android:scaleType="fitCenter"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnStartTasting"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="DEGUSTAÇÃO"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F28C28"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
</FrameLayout>
