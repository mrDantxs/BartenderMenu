<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <include layout="@layout/include_top_back"/>


        <!-- Cabeçalho com Progresso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/textViewProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drink 1 de 5"
                android:textColor="#8b949e"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressTint="#58a6ff" />

        </LinearLayout>

        <!-- Imagem do Drink -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/imageViewDrink"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                android:background="#30363d"
                android:src="@drawable/ic_drink_placeholder"
                android:contentDescription="Foto do drink" />

        </LinearLayout>

        <!-- Nome do Drink -->
        <TextView
            android:id="@+id/textViewDrinkName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F28C28"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Descrição do Drink -->
        <TextView
            android:id="@+id/textViewDrinkDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição do drink aqui..."
            android:textColor="#c9d1d9"
            android:textSize="18sp"
            android:lineSpacingExtra="6sp"
            android:gravity="center"
            android:layout_marginBottom="48dp"
            android:padding="16dp" />

        <!-- Pergunta -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qual sua opinião sobre este drink?"
            android:textColor="#f0f6fc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp" />

        <!-- Botões de Avaliação -->
        <!-- Botões de Avaliação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <Button
                android:id="@+id/buttonLike"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="GOSTO MUITO"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#C7F0BD"/>

            <Button
                android:id="@+id/buttonMedium"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="GOSTO MÉDIO"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFF9C4"/>

            <Button
                android:id="@+id/buttonDislike"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="NÃO GOSTEI"
                android:textColor="#000000"
                android:backgroundTint="#FFAAA5"/>

        </LinearLayout>


        <!-- Instrução -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escolha uma opção para continuar"
            android:textColor="#8b949e"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>